# Postgres
DATABASE_URL=postgres://lahzo:lahzo@localhost:5432/lahzo

# HubSpot Private App (Settings > Integrations > Private Apps in your dev test account)
HUBSPOT_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HubSpot Developer App client secret (used to verify the X-HubSpot-Signature-v3 header)
HUBSPOT_WEBHOOK_SECRET=

# Server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Worker
WORKER_POLL_INTERVAL_MS=500
WORKER_MAX_ATTEMPTS=5
WORKER_STALE_LOCK_TIMEOUT_MS=300000

# HubSpot rate limiter
HUBSPOT_RATE_LIMIT_PER_10S=100
